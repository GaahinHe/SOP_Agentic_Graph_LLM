# SPDX-License-Identifier: MIT
# Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env with real secrets to version control

# =============================================================================
# PROJECT IDENTITY
# =============================================================================
COMPOSE_PROJECT_NAME=pipeline

# =============================================================================
# MINIO (Object Storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password

# =============================================================================
# POSTGRESQL (Metadata Store)
# =============================================================================
POSTGRES_DB=agentic_graph
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=changeme_postgres_password

# =============================================================================
# REDIS (Cache/Queue)
# =============================================================================
REDIS_PASSWORD=changeme_redis_password

# =============================================================================
# NEO4J (Graph Database)
# =============================================================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password

# =============================================================================
# Qdrant (Vector Database)
# =============================================================================
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# =============================================================================
# LLM PROVIDER (Agentic RAG / Graphify)
# =============================================================================
LLM_API_BASE=https://api.minimax.io/anthropic
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=MiniMax-M3
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8192

# =============================================================================
# AGENTIC RAG Configuration
# =============================================================================
AGENTIC_RAG_MODEL=gpt-4o
AGENTIC_RAG_MODEL_API_KEY=your_llm_api_key_here
AGENTIC_RAG_MODEL_BASE_URL=https://api.minimax.io/anthropic
AGENTIC_RAG_RETRIEVAL_TOP_K=10
AGENTIC_RAG_MAX_RETRIEVAL=20
AGENTIC_RAG_CACHE_TTL=3600

# =============================================================================
# EMBEDDING Configuration
# =============================================================================
EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072

# =============================================================================
# MINERU Configuration
# =============================================================================
MINERU_CORE_URL=http://mineru-core:8003
MINERU_BACKEND=hybrid-auto-engine
MINERU_LANG=ch
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
MINERU_OCR_ENABLE=true
MINERU_WRAPPER_WORKER_COUNT=4
MINERU_CORE_WORKER_THREADS=4
MINERU_CORE_MAX_BATCH_SIZE=8
MINERU_MAX_PAGE_COUNT=500

# =============================================================================
# MYMUPDF Configuration
# =============================================================================
MYMUPDF_WORKER_COUNT=4
MYMUPDF_MAX_FILE_SIZE=100MB
MYMUPDF_OCR_ENABLED=true
MYMUPDF_OCR_LANGUAGES=eng,chi_sim,chi_tra,jpn,kor

# =============================================================================
# GRAPHIFY Configuration
# =============================================================================
GRAPHIFY_WORKER_COUNT=4
GRAPHIFY_ENTITY_MODEL=ner
GRAPHIFY_RELATION_MODEL=re
GRAPHIFY_CHUNK_SIZE=512
GRAPHIFY_MAX_ENTITIES_PER_CHUNK=20
GRAPHIFY_MAX_RELATIONS_PER_CHUNK=15

# =============================================================================
# AGENTIC WIKI Configuration
# =============================================================================
WIKI_LANGUAGES=en,zh
WIKI_UPDATE_INTERVAL=86400

# =============================================================================
# GPU Configuration
# =============================================================================
CUDA_VISIBLE_DEVICES=0
ENABLE_GPU=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# OPTIONAL: MONITORING
# =============================================================================
GRAFANA_PASSWORD=changeme_grafana_password